#!/usr/bin/env bash

# exit immediately if any command fails
set -e 

# export 
bin/export                    

# remove symlink if it exists 
if [ -L docs/smartworks ]; then
  rm docs/smartworks
fi

# final git commit 
git add .                   
git commit -am"chore: export to HTML" 

# push
echo "----- PUSH TO GITHUB"  
git push --follow-tags
